            }):Play()
        end)

        if #TextboxActual.Text > 0 then
            ClearBtn.ImageTransparency = 0
            EditIcon.ImageTransparency = 1
        end

        if TextboxConfig.Flag then
            OrionLib.Flags[TextboxConfig.Flag] = Textbox
        end
        return Textbox
end

