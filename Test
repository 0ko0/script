local function IsTargetHit()
    local currentStand = stand.Value
    local currentAttri = attri.Value

    if not currentStand or currentStand == "None" or currentStand == "" then return false end
    local currentStandName = GetFullStandName(currentStand)

    if getgenv().UseSpecificRoll and type(getgenv().SpecificSlots) == "table" then
        for _, slot in pairs(getgenv().SpecificSlots) do
            if type(slot) == "table" then
                local targetStand = slot.Stand or "None"
                local targetAttr = slot.Attribute or "None"
                
                if targetStand ~= "None" or targetAttr ~= "None" then
                    local matchStand = (targetStand == "None" or targetStand == currentStandName)
                    local matchAttr = (targetAttr == "None" or targetAttr == currentAttri)
                    
                    if matchStand and matchAttr then
                        return true
                    end
                end
            end
        end
    end

    local hitStand = false
    if type(getgenv().TargetStandsNames) == "table" and #getgenv().TargetStandsNames > 0 then
        for _, name in pairs(getgenv().TargetStandsNames) do
            if StandDict[name] and StandDict[name] == currentStand then 
                hitStand = true
                break 
            end
        end
    end

    local hitAttri = false
    if type(getgenv().TargetAttributes) == "table" and #getgenv().TargetAttributes > 0 then
        if currentAttri and currentAttri ~= "None" and currentAttri ~= "" then
            if table.find(getgenv().TargetAttributes, currentAttri) then 
                hitAttri = true 
            end
        end
    end

    local mode = getgenv().RollMode
    if mode == "stand or attribute" then
        local checkS = (#getgenv().TargetStandsNames > 0)
        local checkA = (#getgenv().TargetAttributes > 0)
        if checkS and checkA then 
            return (hitStand or hitAttri)
        elseif checkS then 
            return hitStand
        elseif checkA then 
            return hitAttri 
        end
    elseif mode == "stand only" then
        return hitStand
    elseif mode == "attribute only" then 
        return hitAttri
    elseif mode == "stand and attribute" then 
        return (hitStand and hitAttri)
    elseif mode == "Kars" then 
        return hitAttri 
    end
    
    return false
end

