local function farm()
    task.spawn(function()
        local questDebounce = 0 
        local lastAttackTime = 0
        local currentTarget = nil 

        while task.wait() do
            if not getgenv().AutoFarm then
                currentTarget = nil 
                task.wait(0.2)
                continue
            end

            local now = tick()
            local hrp = getHRP()
            if not hrp then continue end
            
            if hrp.Anchored then hrp.Anchored = false end

            local currentNpcObj = npc()
            
            
            local validQuestToFarm = nil
            local hasAnyCompletedQuest = false

            for _, q in pairs(Quests:GetChildren()) do
                if q:FindFirstChild("Enemy") then
                    local isComplete = (q:FindFirstChild("Completed") and q.Completed.Value == true) or
                                       (q:FindFirstChild("Kills") and q:FindFirstChild("MaxKills") and q.Kills.Value >= q.MaxKills.Value)
                    
                    if isComplete then
                        hasAnyCompletedQuest = true
                    else
                        validQuestToFarm = q 
                    end
                end
            end
            
      
            if not validQuestToFarm then
                currentTarget = nil 
                OPHover_Remove() 
                
                if typeof(currentNpcObj) == "Instance" then
                    
                    local platform = getOrCreatePlatform(currentNpcObj)
                    if platform then
                        hrp.Velocity = Vector3.new(0, 0, 0)
                        hrp.CFrame = platform.CFrame * CFrame.new(0, 3.5, 0)
                    end

                    if now - questDebounce > 1 then 
                        if hasAnyCompletedQuest then
                            
                            if currentNpcObj:FindFirstChild("QuestDone") then
                                currentNpcObj.QuestDone:FireServer()
                            end
                            
                            
                            local npcsFolder = workspace:FindFirstChild("Map") and workspace.Map:FindFirstChild("NPCs")
                            if npcsFolder then
                                for _, v in ipairs(npcsFolder:GetChildren()) do
                                    if v:FindFirstChild("QuestDone") then
                                        v.QuestDone:FireServer()
                                    end
                                end
                            end
                        end
                        
           
                        if currentNpcObj:FindFirstChild("Done") then
                            currentNpcObj.Done:FireServer()
                        end
                        questDebounce = tick()
                    end
                end
                continue 
            end
           
            
            local enemyName = validQuestToFarm.Enemy.Value
            
            if not currentTarget or not currentTarget.Parent or not currentTarget:FindFirstChild("Humanoid") or currentTarget.Humanoid.Health <= 0 then
                currentTarget = find(enemyName)
            end

            if currentTarget then
                local targetHRP = currentTarget:FindFirstChild("HumanoidRootPart")

                if targetHRP then
                    local distToTarget = (hrp.Position - targetHRP.Position).Magnitude
                                        
                    
                    if distToTarget > 300 then
                        hrp.CFrame = targetHRP.CFrame * CFrame.new(0, 50, 0)
                        hrp.Velocity = Vector3.new(0,0,0)
                        task.wait(0.1) 
                    end

                    OPHover_Lock(hrp, targetHRP, getgenv().Distance, "Under_OP")
                    
                    distToTarget = (hrp.Position - targetHRP.Position).Magnitude
                                       
                    if distToTarget <= (getgenv().Distance + 10) then
                        if now - lastAttackTime >= getgenv().AttackDelay then
                            executeSkills(getgenv().SelectedFarmSkills)
                            lastAttackTime = now
                        end
                    end
                end
            else
                
                OPHover_Remove() 
                if typeof(currentNpcObj) == "Instance" then
                    local platform = getOrCreatePlatform(currentNpcObj)
                    if platform then
                        hrp.Velocity = Vector3.new(0, 0, 0)
                        hrp.CFrame = platform.CFrame * CFrame.new(0, 3.5, 0)
                    end
                end
                task.wait(0.2) 
            end
        end
    end)
end

