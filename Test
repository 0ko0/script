local function applyPlayerESP(player, char)
    if not char then return end
    if char == LocalPlayer.Character then return end
    
    local highlight = char:FindFirstChild("LurixPlayerESP")
    if not highlight then
        highlight = Instance.new("Highlight")
        highlight.Name = "LurixPlayerESP"
        highlight.Parent = char
    end
    highlight.FillColor = Color3.fromRGB(80, 150, 255)
    highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
    highlight.FillTransparency = 0.6
    highlight.OutlineTransparency = 0
    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    
    local head = char:WaitForChild("Head", 5)
    if not head then return end
    
    local billboard = char:FindFirstChild("LurixPlayerUIESP")
    if not billboard then
        billboard = Instance.new("BillboardGui")
        billboard.Name = "LurixPlayerUIESP"
        billboard.Adornee = head
        billboard.Size = UDim2.new(0, 200, 0, 75)
        billboard.StudsOffset = Vector3.new(0, 4, 0)
        billboard.AlwaysOnTop = true
        billboard.Parent = char
        
        local textLabel = Instance.new("TextLabel")
        textLabel.Name = "InfoLabel"
        textLabel.Size = UDim2.new(1, 0, 1, 0)
        textLabel.BackgroundTransparency = 1
        textLabel.TextStrokeTransparency = 0
        textLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
        textLabel.Font = Enum.Font.GothamBold
        textLabel.TextSize = getgenv().ESPTextSize
        textLabel.RichText = true
        textLabel.Parent = billboard
    end
    
    local infoLabel = billboard:FindFirstChild("InfoLabel")
    local humanoid = char:WaitForChild("Humanoid", 5)
    local charConnections = {}
    
    local function updateText()
        if not infoLabel then return end
        
        infoLabel.TextSize = getgenv().ESPTextSize
        
        local lines = {}
        
        if getgenv().ESPShowName then
            table.insert(lines, string.format("<b><font color=\"rgb(255,255,255)\">%s</font></b>", player.DisplayName))
        end
        
        if getgenv().ESPShowHealth then
            local hp = humanoid and math.floor(humanoid.Health) or 0
            local maxHp = humanoid and math.floor(humanoid.MaxHealth) or 100
            local ratio = math.clamp(hp / maxHp, 0, 1)
            local r = math.floor(math.clamp(510 * (1 - ratio), 0, 255))
            local g = math.floor(math.clamp(510 * ratio, 0, 255))
            local hpColorStr = string.format("rgb(%d,%d,0)", r, g)
            table.insert(lines, string.format("<font color=\"%s\">HP: %d/%d</font>", hpColorStr, hp, maxHp))
        end
        
        local standName = "None"
        local attriName = "None"
        local playerData = player:FindFirstChild("Data")
        if playerData then
            local standVal = playerData:FindFirstChild("Stand")
            if standVal then
                standName = (standVal.Value ~= "" and standVal.Value ~= "None") and standVal.Value or "None"
            end
            local attriVal = playerData:FindFirstChild("Attri")
            if attriVal then
                attriName = (attriVal.Value ~= "" and attriVal.Value ~= "None") and attriVal.Value or "None"
            end
        end
        
        if getgenv().ESPShowStand then
            table.insert(lines, string.format("<font color=\"rgb(255, 200, 80)\">Stand: %s</font>", standName))
        end
        
        if getgenv().ESPShowAttri then
            table.insert(lines, string.format("<font color=\"rgb(255, 100, 255)\">Attr: %s</font>", attriName))
        end
        
        infoLabel.Text = table.concat(lines, "\n")
    end
    
    updateText()
    activeEspUpdates[char] = updateText
    
    if humanoid then
        table.insert(charConnections, humanoid:GetPropertyChangedSignal("Health"):Connect(updateText))
        table.insert(charConnections, humanoid:GetPropertyChangedSignal("MaxHealth"):Connect(updateText))
    end
    
    task.spawn(function()
        local playerData = player:WaitForChild("Data", 5)
        if playerData then
            local standVal = playerData:WaitForChild("Stand", 5)
            if standVal then
                table.insert(charConnections, standVal:GetPropertyChangedSignal("Value"):Connect(updateText))
            end
            local attriVal = playerData:WaitForChild("Attri", 5)
            if attriVal then
                table.insert(charConnections, attriVal:GetPropertyChangedSignal("Value"):Connect(updateText))
            end
            updateText()
        end
    end)
    
    local destroyConn
    destroyConn = char.Destroying:Connect(function()
        for _, c in ipairs(charConnections) do
            if c then c:Disconnect() end
        end
        activeEspUpdates[char] = nil
        if destroyConn then destroyConn:Disconnect() end
    end)
end

