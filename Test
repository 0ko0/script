local function GetFarmPosition(lvl)
    local maxValidLevel = 1
    for reqLvl, _ in pairs(FarmPositions) do
        if lvl >= reqLvl and reqLvl > maxValidLevel then
            maxValidLevel = reqLvl
        end
    end
    return FarmPositions[maxValidLevel]
end

