local function TestExecutorCompatibility()
    local apiList = {
        
        { name = "readfile", func = function() return readfile ~= nil end, category = "FileSystem", critical = true },
        { name = "writefile", func = function() return writefile ~= nil end, category = "FileSystem", critical = true },
        { name = "makefolder", func = function() return makefolder ~= nil end, category = "FileSystem", critical = false },
        { name = "isfolder", func = function() return isfolder ~= nil end, category = "FileSystem", critical = false },
        { name = "isfile", func = function() return isfile ~= nil end, category = "FileSystem", critical = false },
        { name = "listfiles", func = function() return listfiles ~= nil end, category = "FileSystem", critical = false },
        
        { name = "request", func = function() return (http_request or request or (syn and syn.request) or (fluxus and fluxus.request)) ~= nil end, category = "Http", critical = true },
        { name = "getcustomasset", func = function() return (getcustomasset or getsynasset) ~= nil end, category = "Http", critical = false },
        
        { name = "getgenv", func = function() return getgenv ~= nil end, category = "Environment", critical = true },
        { name = "getgc", func = function() return getgc ~= nil end, category = "Environment", critical = false },
        { name = "getconstants", func = function() return (debug and debug.getconstants) or getconstants ~= nil end, category = "Environment", critical = false },
        { name = "setconstant", func = function() return (debug and debug.setconstant) or setconstant ~= nil end, category = "Environment", critical = false },
        
        { name = "fireproximityprompt", func = function() return fireproximityprompt ~= nil end, category = "Instance", critical = false },
        { name = "firetouchinterest", func = function() return firetouchinterest ~= nil end, category = "Instance", critical = false },
        
        { name = "queue_on_teleport", func = function() return (queue_on_teleport or (syn and syn.queue_on_teleport) or (fluxus and fluxus.queue_on_teleport) or queueonteleport) ~= nil end, category = "Utils", critical = false },
        { name = "setclipboard", func = function() return setclipboard ~= nil end, category = "Utils", critical = false },
        { name = "identifyexecutor", func = function() return identifyexecutor ~= nil end, category = "Utils", critical = false }
    }

    local totalApis = #apiList
    local passedCount = 0
    local missingFeatures = {}
    local criticalMissing = false

    print("\n[ LURIX HUB - EXECUTOR UNC COMPATIBILITY TEST ]")
    
    for _, api in ipairs(apiList) do
        local success, result = pcall(api.func)
        local isSupported = success and result
        
        if isSupported then
            passedCount = passedCount + 1
            print(string.format("[+] %-12s [%s] -> PASSED", "[" .. api.category .. "]", api.name))
        else
            print(string.format("[-] %-12s [%s] -> FAILED", "[" .. api.category .. "]", api.name))
            table.insert(missingFeatures, api.name)
            if api.critical then
                criticalMissing = true
            end
        end
    end

    local rate = math.floor((passedCount / totalApis) * 100)
    print(string.format("\nCompatibility Rate: %d%% (%d/%d)", rate, passedCount, totalApis))

    local isSupported = true
    local statusMsg = ""
    local statusTitle = "Executor Compatible"

    if criticalMissing then
        isSupported = false
        statusTitle = "Executor Warning"
        statusMsg = string.format("Incompatible (%d%%). Missing critical features: %s. Check F9 console", rate, table.concat(missingFeatures, ", "))
    elseif #missingFeatures > 0 then
        statusTitle = "Executor Notice"
        statusMsg = string.format("Partially compatible (%d%%). Missing minor features: %s. Check F9 console", rate, table.concat(missingFeatures, ", "))
    else
        statusMsg = string.format("Fully compatible (%d%%). All %d required APIs are supported", rate, totalApis)
    end

    pcall(function()
        OrionLib:MakeNotification({
            Name = statusTitle,
            Content = statusMsg,
            Time = 10,
            Image = "rbxassetid://118254173055216"
        })
    end)
    
    return isSupported, criticalMissing
end

