local function IsSlotUnlocked(slotIndex)
    if slotIndex == 1 or slotIndex == 2 then
        return true
    end
    
    local gamepassesFolder = game:GetService("ReplicatedStorage"):FindFirstChild("Gamepasses")
    
    if slotIndex == 3 then
        local gp1 = gamepassesFolder and gamepassesFolder:FindFirstChild("StandStorage1")
        local gp1Alt = gamepassesFolder and gamepassesFolder:FindFirstChild("AltStandStorage1")
        if gp1 and checkGamepassOwnership(gp1.Value) then return true end
        if gp1Alt and checkGamepassOwnership(gp1Alt.Value) then return true end
        return false
    elseif slotIndex == 4 then
        local levelVal = Data:FindFirstChild("Level")
        return levelVal and levelVal.Value >= 120
    elseif slotIndex == 5 then
        local gp2 = gamepassesFolder and gamepassesFolder:FindFirstChild("StandStorage2")
        if gp2 and checkGamepassOwnership(gp2.Value) then return true end
        return false
    end
    
    return false
end

local function SafeStoreStand(currentStand)
    local stored = false
    local switchStandEvent = game:GetService("ReplicatedStorage"):WaitForChild("Events"):WaitForChild("SwitchStand", 5)
    if not switchStandEvent then return false end
    local currentStandName = GetFullStandName(currentStand)

    for i = 1, 5 do 
        if IsSlotUnlocked(i) then
            local slotData = Data:FindFirstChild("Slot"..i.."Stand")
            if slotData then
                local isLocked = slotData:FindFirstChild("Locked")
                local hasLockValue = isLocked and isLocked:IsA("BoolValue") and isLocked.Value
                local isEmpty = (slotData.Value == "" or slotData.Value == "None" or slotData.Value == nil)
                
                if not hasLockValue and isEmpty then
                    local initialStand = stand.Value
                    
                    pcall(function()
                        switchStandEvent:FireServer("Slot"..i)
                    end)
                    
                    local t = tick()
                    while stand.Value == initialStand and (tick() - t < 4) and OrionLib.Flags["ToggleAutoRoll"].Value do 
                        task.wait(0.1) 
                    end
                    
                    if stand.Value == "None" or stand.Value == "" then
                        stored = true
                        pcall(function()
                            OrionLib:MakeNotification({
                                Name = "Storage Success", 
                                Content = string.format("Stored [%s] in Slot %d\nContinuing to roll...", currentStandName, i), 
                                Time = 5, 
                                Image = "rbxassetid://4483345998"
                            })
                        end)
                        break
                    end
                end
            end
        end
    end
    return stored
end

