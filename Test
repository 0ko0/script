local function hasStandEquipped(character)
    
    if not stand or stand.Value == "None" or stand.Value == "" then 
        return true 
    end

    
    local standOutVal = character:FindFirstChild("StandOut") or character:FindFirstChild("IsStandOut")
    if standOutVal and standOutVal:IsA("BoolValue") then
        return standOutVal.Value
    end

    
    for _, child in ipairs(character:GetChildren()) do
        if child:IsA("Model") and not child:IsA("Accessory") then
            
            if child:FindFirstChildOfClass("AnimationController") or child:FindFirstChild("HumanoidRootPart") or child.Name == stand.Value then
                for _, part in ipairs(child:GetDescendants()) do
                    if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" and part.Transparency < 1 then
                        return true 
                    end
                end
            end
        end
    end
    return false 
end

local function summon()
    task.spawn(function()
        local lastSummonTick = 0
        
        while task.wait(0.3) do 
            if getgenv().AutoFarm or getgenv().AutoLair or getgenv().AutoBoss then
                
                if stand.Value == "None" or stand.Value == "" then continue end
                
                local character = LocalPlayer.Character
                if character then
                    local humanoid = character:FindFirstChild("Humanoid")
                    
                    
                    if humanoid and humanoid.Health > 0 and humanoid:GetState() ~= Enum.HumanoidStateType.Dead and humanoid:GetState() ~= Enum.HumanoidStateType.Physics then
                        
                        local standEvents = character:FindFirstChild("StandEvents")
                        if standEvents then
                            local summonEvent = standEvents:FindFirstChild("Summon")
                            
                            if summonEvent and summonEvent:IsA("RemoteEvent") then
                                if not hasStandEquipped(character) then
                                    
                                    if tick() - lastSummonTick > 2.5 then
                                        summonEvent:FireServer()
                                        lastSummonTick = tick()
                                    end
                                else
                                    
                                    if tick() - lastSummonTick > 5 then
                                        lastSummonTick = 0 
                                    end
                                end
                            end
                        end
                    end
                end
            else
                task.wait(1) 
            end
        end
    end)
end

