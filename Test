    local livingFolder = workspace:FindFirstChild("Living")
    if not livingFolder or not MyLairCFrame then return nil end

    local hrp = getHRP()
    if not hrp then return nil end

    local closestBoss = nil
    local shortestDist = math.huge 

    for _, entity in ipairs(livingFolder:GetChildren()) do
        if string.find(entity.Name, "Boss") or entity.Name == "realboss" then
            local targetHrp = entity:FindFirstChild("HumanoidRootPart")
            
            
            if targetHrp then 
                
                if isInsideMyLair(targetHrp.Position) then
                    local dist = (hrp.Position - targetHrp.Position).Magnitude
                    if dist < shortestDist then
