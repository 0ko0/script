local function OPHover_Lock(playerHRP, targetHRP, distance, mode)
    if not playerHRP or not targetHRP then return end
    
    local bv = playerHRP:FindFirstChild("OP_Flight_BV")
    if not bv then
        bv = Instance.new("BodyVelocity")
        bv.Name = "OP_Flight_BV"
        bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge) 
        bv.Velocity = Vector3.new(0, 0, 0)
        bv.Parent = playerHRP
    end

    local bg = playerHRP:FindFirstChild("OP_Flight_BG")
    if not bg then
        bg = Instance.new("BodyGyro")
        bg.Name = "OP_Flight_BG"
        bg.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
        bg.D = 100
        bg.P = 10000
        bg.Parent = playerHRP
    end

    playerHRP.Velocity = Vector3.new(0, 0, 0)
    playerHRP.RotVelocity = Vector3.new(0, 0, 0)

    local finalCFrame
    if mode == "Under_OP" or mode == "Below_Boss" then
        
        finalCFrame = targetHRP.CFrame * CFrame.new(0, -distance, 0) * CFrame.Angles(math.rad(90), 0, 0)
    elseif mode == "Above" then
        
        finalCFrame = targetHRP.CFrame * CFrame.new(0, distance, 0) * CFrame.Angles(math.rad(-90), 0, 0)
    elseif mode == "Behind" then
        
        finalCFrame = targetHRP.CFrame * CFrame.new(0, 0, distance)
    else
        finalCFrame = targetHRP.CFrame * CFrame.new(0, 0, distance)
    end
  
    playerHRP.CFrame = playerHRP.CFrame:Lerp(finalCFrame, 0.85)
    bg.CFrame = finalCFrame
end

