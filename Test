local function getClosestItem(playerHRP)
    local closestPart = nil
    local closestPrompt = nil
    local shortestDistance = math.huge

    for part, prompt in pairs(itemCache) do
        if part and part.Parent and prompt and prompt.Parent and prompt.Enabled then
            local distance = (playerHRP.Position - part.Position).Magnitude
            if distance < shortestDistance then
                shortestDistance = distance
                closestPart = part
                closestPrompt = prompt
            end
        else
            itemCache[part] = nil
        end
    end
    return closestPart, closestPrompt
end

