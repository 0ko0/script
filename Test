local function startPlayerESP()
    local function handlePlayer(player)
        if player == LocalPlayer then return end
        
        local function onCharAdded(char)
            if getgenv().PlayerESPHighlight then
                task.wait(0.5)
                applyPlayerESP(player, char)
            end
        end
        
        if player.Character then
            onCharAdded(player.Character)
        end
        
        local conn = player.CharacterAdded:Connect(onCharAdded)
        table.insert(playerEspConnections, conn)
    end

    for _, p in ipairs(Players:GetPlayers()) do
        handlePlayer(p)
    end
    
    local playerJoinConn = Players.PlayerAdded:Connect(handlePlayer)
    table.insert(playerEspConnections, playerJoinConn)
end

local function stopPlayerESP()
    for _, conn in ipairs(playerEspConnections) do
        if conn then conn:Disconnect() end
    end
    table.clear(playerEspConnections)
    table.clear(activeEspUpdates)
    
    for _, p in ipairs(Players:GetPlayers()) do
        if p.Character then 
            removePlayerESP(p.Character) 
        end
    end
end

