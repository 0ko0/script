local function LoadTargetPlayerData(playerName)
    if not ScrollContainer then return end

    for _, child in ipairs(ScrollContainer:GetChildren()) do
        if child:IsA("Frame") then child:Destroy() end
    end
    for _, conn in ipairs(ActiveDataConnections) do
        conn:Disconnect()
    end
    table.clear(ActiveDataConnections)

    local targetPlayer = Players:FindFirstChild(playerName)
    if not targetPlayer then
        TitleLabel.Text = "player: player not found"
        return
    end

    local targetData = targetPlayer:FindFirstChild("Data")
    if not targetData then
        TitleLabel.Text = "player: " .. string.upper(playerName) .. " (no data)"
        return
    end

    TitleLabel.Text = "player: " .. string.upper(playerName)

    local dataList = {}
    for _, v in pairs(targetData:GetChildren()) do
        if not IgnoreData[v.Name] and v:IsA("ValueBase") then table.insert(dataList, v) end
    end
    table.sort(dataList, function(a, b) return a.Name < b.Name end)

    for i, v in ipairs(dataList) do
        local Row = Instance.new("Frame", ScrollContainer)
        Row.Size = UDim2.new(1, -20, 0, 26)
        Row.BackgroundColor3 = Color3.fromRGB(25, 25, 30)
        Row.BorderSizePixel = 0
        Row.LayoutOrder = i
        
        Instance.new("UICorner", Row).CornerRadius = UDim.new(0, 4)

        local NameLabel = Instance.new("TextLabel", Row)
        NameLabel.Size = UDim2.new(0.45, -10, 1, 0)
        NameLabel.Position = UDim2.new(0, 10, 0, 0)
        NameLabel.BackgroundTransparency = 1
        NameLabel.Font = Enum.Font.GothamSemibold
        NameLabel.TextSize = 12
        NameLabel.TextColor3 = Color3.fromRGB(80, 200, 255)
        NameLabel.TextXAlignment = Enum.TextXAlignment.Left
        NameLabel.Text = v.Name

        local ValueLabel = Instance.new("TextLabel", Row)
        ValueLabel.Size = UDim2.new(0.55, -10, 1, 0)
        ValueLabel.Position = UDim2.new(0.45, 0, 0, 0)
        ValueLabel.BackgroundTransparency = 1
        ValueLabel.Font = Enum.Font.GothamBold
        ValueLabel.TextSize = 12
        ValueLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
        ValueLabel.TextXAlignment = Enum.TextXAlignment.Right
        
        local initialVal = tostring(v.Value)
        ValueLabel.Text = (initialVal == "" or initialVal == "nil") and "[empty]" or initialVal

        local conn = v:GetPropertyChangedSignal("Value"):Connect(function()
            local newVal = tostring(v.Value)
            ValueLabel.Text = (newVal == "" or newVal == "nil") and "[empty]" or newVal
            
            ValueLabel.TextColor3 = Color3.fromRGB(0, 255, 128)
            task.delay(0.6, function()
                if ValueLabel then ValueLabel.TextColor3 = Color3.fromRGB(200, 200, 200) end
            end)
        end)
        table.insert(ActiveDataConnections, conn)
    end
end

