local function isInsideMyLair(targetPos)
    if not MyLairCFrame or not MyLairSize then return false end
    
    local relativePosition = MyLairCFrame:PointToObjectSpace(targetPos)
    local halfSize = MyLairSize / 2
    
    return math.abs(relativePosition.X) <= halfSize.X
       and math.abs(relativePosition.Y) <= halfSize.Y
       and math.abs(relativePosition.Z) <= halfSize.Z
end

local function lockMyLair()
    local hrp = getHRP()
    if not hrp then return end

    local mapNames = {"Lvl 15 Lair", "DIODUNGEON", "Lvl80Dungeon", "Lvl100Dungeon", "Level200Dungeon"}
    
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("Model") and table.find(mapNames, obj.Name) then
            local pivot = obj:GetPivot().Position
            if (hrp.Position - pivot).Magnitude < 200 then
                
                local cf, size = obj:GetBoundingBox()
                MyLairCFrame = cf
                
                MyLairSize = size + Vector3.new(60, 60, 60)
                obj.Name = "Locked_Lair" 
