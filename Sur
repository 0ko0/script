    local playerEntity = workspace:FindFirstChild("Living") and workspace.Living:FindFirstChild(playerName)
    
    if playerEntity and playerEntity:FindFirstChild("InLair") then
        return playerEntity.InLair.Value
    end
    
    return false
end

local function lairnpc(levelString)
    local npcsFolder = workspace:FindFirstChild("Map") and workspace.Map:FindFirstChild("NPCs")
    if not npcsFolder then return nil end

    for _, v in pairs(npcsFolder:GetChildren()) do
        if v.Name == "i_stabman" and v:FindFirstChild("Head") and v.Head:FindFirstChild("Main") then
            local success, text = pcall(function() 
                local textObj = v.Head.Main.Text
                if typeof(textObj) == "Instance" then return textObj.Text end
                return textObj
            end)
                        
            if success and type(text) == "string" and string.find(text, levelString) then
                return v
            end
        end
    end
    return nil
end

local function dungeon()
    local character = LocalPlayer.Character
    local hrp = character and character:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end

    local overlapParams = OverlapParams.new()
    overlapParams.FilterType = Enum.RaycastFilterType.Include
    overlapParams.FilterDescendantsInstances = {hrp}
    
    local mapNames = {"Lvl 15 Lair", "DIODUNGEON", "Lvl80Dungeon", "Lvl100Dungeon", "Level200Dungeon", "myDungeon"}

    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("Model") and table.find(mapNames, obj.Name) then
            local modelCFrame, modelSize = obj:GetBoundingBox()
            local partsInBox = workspace:GetPartBoundsInBox(modelCFrame, modelSize, overlapParams)
         
            if #partsInBox > 0 then
                if obj.Name ~= "myDungeon" then
                    obj.Name = "myDungeon" 
                end
                return obj
            end
        end
    end
    return nil
end

local function findBoss()
    local livingFolder = workspace:FindFirstChild("Living")
    if not livingFolder then return nil end

    local myDungeon = dungeon()
    if not myDungeon then return nil end 

    local dungeonCFrame, dungeonSize = myDungeon:GetBoundingBox()

    local closestBoss = nil
    local shortestDistance = math.huge
    
    local character = LocalPlayer.Character
    local hrp = character and character:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end

    for _, entity in pairs(livingFolder:GetChildren()) do
        if entity.Name == "Boss" or entity.Name == "realboss" or string.find(entity.Name, "Boss") then
            local humanoid = entity:FindFirstChild("Humanoid")
            local targetHrp = entity:FindFirstChild("HumanoidRootPart")
                        
            if humanoid and targetHrp then
                
                local overlapParams = OverlapParams.new()
                overlapParams.FilterType = Enum.RaycastFilterType.Include
                overlapParams.FilterDescendantsInstances = {targetHrp}

                local partsInBox = workspace:GetPartBoundsInBox(dungeonCFrame, dungeonSize, overlapParams)
                
                if #partsInBox > 0 then 
                    local distance = (hrp.Position - targetHrp.Position).Magnitude
                    if distance < shortestDistance then
                        shortestDistance = distance
                        closestBoss = entity
                    end
                end
            end
        end
    end
    
    return closestBoss
end

local function lair()
    task.spawn(function()
        local hasLoadedLair = false 
        local lastLairAttackTime = 0 

        while task.wait() do 
            if getgenv().AutoLair then
                if not inlair() then
                    hasLoadedLair = false 
                    
                    local character = LocalPlayer.Character
                    local playerHRP = character and character:FindFirstChild("HumanoidRootPart")
                   
                    if getgenv().SelectedLair == "200+" and playerHRP then
                        local inSanctum = false
                                             
                        local sanctum = workspace:FindFirstChild("Map") 
                            and workspace.Map:FindFirstChild("InnerSanctum") 
                            and workspace.Map.InnerSanctum:FindFirstChild("Sanctum")
                                              
                        if sanctum then
                            local sanctumPos
                            if sanctum:IsA("BasePart") then
                                sanctumPos = sanctum.Position
                            elseif sanctum:IsA("Model") then
                                sanctumPos = sanctum:GetBoundingBox().Position
                            end
                                                    
                            if sanctumPos and (playerHRP.Position - sanctumPos).Magnitude < 600 then
                                inSanctum = true
                            end
                        end
                                              
                        if not inSanctum then
                            local npc90 = lairnpc("90+")
                            if npc90 then
                                local npc90Part = npc90:FindFirstChild("HumanoidRootPart") or npc90:FindFirstChild("Head")
                                if npc90Part then
                                    playerHRP.CFrame = npc90Part.CFrame * CFrame.new(0, 0, 3)
                                    playerHRP.Velocity = Vector3.new(0, 0, 0)
                                    task.wait(0.5)
                                    
                                    if npc90:FindFirstChild("Done") then
                                        npc90.Done:FireServer()
                                        task.wait(2) 
                                    end
                                end
                            end
                        end
                    end
                                        
                    character = LocalPlayer.Character
                    playerHRP = character and character:FindFirstChild("HumanoidRootPart")
                    
                    local npc = lairnpc(getgenv().SelectedLair)
                    if npc then
                        local npcPart = npc:FindFirstChild("HumanoidRootPart") or npc:FindFirstChild("Head")
                        
                        if playerHRP and npcPart then
                            playerHRP.CFrame = npcPart.CFrame * CFrame.new(0, 0, 3)
                            playerHRP.Velocity = Vector3.new(0, 0, 0)                                                
                            
                            task.wait(0.5) 
                                                        
                            if npc:FindFirstChild("Done") then
                                npc.Done:FireServer()
                                task.wait(2) 
                            end
                        end
                    end
                else  
                    
                    if not hasLoadedLair then
                        task.wait(1) 
                        hasLoadedLair = true
                    end
                    
                    local boss = findBoss()
                    
                    if boss then
                        if boss.Name ~= "realboss" then
                            boss.Name = "realboss"
                        end

                        local character = LocalPlayer.Character
                        if character and character:FindFirstChild("HumanoidRootPart") then
                            local playerHRP = character.HumanoidRootPart
                            local targetHRP = boss:FindFirstChild("HumanoidRootPart")

                            if targetHRP then
                               
                                local targetPos = targetHRP.Position
                                local belowPos = targetPos - Vector3.new(0, getgenv().Distance, 0) 
                                playerHRP.CFrame = CFrame.new(belowPos, targetPos)
                                playerHRP.Velocity = Vector3.new(0, 0, 0)
                                                                                     
                                if tick() - lastLairAttackTime >= getgenv().AttackDelay then
                                    local standEvents = character:FindFirstChild("StandEvents")
                                    if standEvents then
                                        local m1 = standEvents:FindFirstChild("M1")
                                        if m1 then 
                                            m1:FireServer() 
                                        end
                                    end
                                    lastLairAttackTime = tick()
                                end
                            end
                        end
                    end
                end
            end
        end
    end)
end

local function claimNetworkOwnership()
    pcall(function()
        local sethidden = sethiddenproperty or set_hidden_property or set_hidden_prop
        if sethidden then
            sethidden(LocalPlayer, "SimulationRadius", math.huge)
            sethidden(LocalPlayer, "MaxSimulationRadius", math.huge)
        end
    end)
end

local function instantkill(npc)
    local humanoid = npc:FindFirstChildOfClass("Humanoid")
    if humanoid then        
        humanoid:TakeDamage(math.huge)
        humanoid:ChangeState(Enum.HumanoidStateType.Dead)            
    end
end

local function kill()
    task.spawn(function()
        while task.wait(0.2) do
            
            if getgenv().inskill and inlair() then
                claimNetworkOwnership()
                               
                local livingFolder = workspace:FindFirstChild("Living")
                if livingFolder then
                    for _, obj in ipairs(livingFolder:GetChildren()) do
                        if not getgenv().inskill or not inlair() then break end
                        
                        if obj:IsA("Model") and obj ~= LocalPlayer.Character then
                            
                            if not Players:GetPlayerFromCharacter(obj) then
                                if obj:FindFirstChildOfClass("Humanoid") then
                                    instantkill(obj)
                                end
                            end
                        end
                    end
                end
            end
        end
    end)
end

local function skill()
