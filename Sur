local function farm()
    task.spawn(function()
        while task.wait() do
            if getgenv().AutoFarm then
                local currentQuest = quest()
                local targetNPC = npc() 

                if not currentQuest then
                    pcall(function()
                        if typeof(targetNPC) == "Instance" then
                            targetNPC:WaitForChild("Done"):FireServer()
                        else
                            workspace:WaitForChild("Map"):WaitForChild("NPCs"):WaitForChild(targetNPC):WaitForChild("Done"):FireServer()
                        end
                    end)
                    task.wait(1)

                elseif currentQuest:FindFirstChild("Completed") and (currentQuest.Completed.Value == true or currentQuest.Kills.Value >= currentQuest.MaxKills.Value) then
                    safe()
                    pcall(function()
                        if typeof(targetNPC) == "Instance" then
                            targetNPC:WaitForChild("QuestDone"):FireServer()
                        else
                            workspace:WaitForChild("Map"):WaitForChild("NPCs"):WaitForChild(targetNPC):WaitForChild("QuestDone"):FireServer()
                        end
                    end)
                    task.wait(1.5)

                else
                    local enemyName = currentQuest.Enemy.Value
                    local target = find(enemyName)
                    
                    if target then
                        local targetHum = target:FindFirstChild("Humanoid")
                        local targetHRP = target:FindFirstChild("HumanoidRootPart")
                        local lastAttackTime = 0
                        
                        while target and target.Parent and targetHum and targetHum.Health > 0 and getgenv().AutoFarm do
                            if currentQuest.Kills.Value >= currentQuest.MaxKills.Value then
                                break 
                            end

                            local character = LocalPlayer.Character
                            if character and character:FindFirstChild("HumanoidRootPart") then
                                local playerHRP = character.HumanoidRootPart
                                                     
                                local targetPos = targetHRP.Position
                                local belowPos = targetPos - Vector3.new(0, getgenv().Distance, 0) 
                                playerHRP.CFrame = CFrame.new(belowPos, targetPos)
                                playerHRP.Velocity = Vector3.new(0, 0, 0)
                                                        
                                if tick() - lastAttackTime >= getgenv().AttackDelay then
                                    skill()
                                    lastAttackTime = tick()
                                end
                            end
                            task.wait()
                        end
                    else
                        safe()
                        task.wait(0.5)
                    end
                end
            end
        end
    end)
end

