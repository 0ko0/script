    if not character then return end
    
    local standEvents = character:FindFirstChild("StandEvents")
    if not standEvents then return end

    local m1 = standEvents:FindFirstChild("M1")
    if m1 then m1:FireServer() end

    local heavy = standEvents:FindFirstChild("Heavy")
    if heavy then heavy:FireServer() end

    local barrage = standEvents:FindFirstChild("Barrage")
