                    hrp.CFrame = part.CFrame + Vector3.new(0, getgenv().ItemOffset, 0)
                    
                    task.wait(getgenv().WaitBeforeFire)
                    firePrompt(prompt)
                    task.wait(getgenv().WaitAfterFire)
                else
                    itemCache[part] = nil
                end
            end
        else
            task.wait(0.5) 
        end
    end
end)

