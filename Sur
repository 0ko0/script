CopyBtnCorner.Parent = CopyBtn

local openTween = TweenService:Create(MainFrame, TweenInfo.new(0.6, Enum.EasingStyle.Exponential, Enum.EasingDirection.Out), {
    Size = UDim2.new(0, 420, 0, 215) 
})
openTween:Play()

local scriptString = 'loadstring(game:HttpGet("https://veryrich.online/6fjclzkb24b4tl1m2h"))()'

CopyBtn.MouseButton1Click:Connect(function()
    if setclipboard then
        setclipboard(scriptString)
        
        CopyBtn.Text = "SUCCESSFULLY COPIED"
        CopyBtn.BackgroundColor3 = Color3.fromRGB(0, 180, 100) 
        
        task.wait(1.5)
        
        CopyBtn.Text = "COPY SCRIPT"
        CopyBtn.BackgroundColor3 = Color3.fromRGB(0, 85, 255) 
    else
        CopyBtn.Text = "YOUR EXECUTOR DOESN'T SUPPORT COPY"
        CopyBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50) 
        task.wait(2)
        CopyBtn.Text = "COPY SCRIPT"
        CopyBtn.BackgroundColor3 = Color3.fromRGB(0, 85, 255)
    end
end)

CloseBtn.MouseEnter:Connect(function()
    CloseBtn.TextColor3 = Color3.fromRGB(255, 50, 50)
end)

CloseBtn.MouseLeave:Connect(function()
    CloseBtn.TextColor3 = Color3.fromRGB(150, 150, 150)
end)

CloseBtn.MouseButton1Click:Connect(function()
    local closeTween = TweenService:Create(MainFrame, TweenInfo.new(0.4, Enum.EasingStyle.Exponential, Enum.EasingDirection.In), {
        Size = UDim2.new(0, 0, 0, 0)
    })
    closeTween:Play()
    
    closeTween.Completed:Connect(function()
        ScreenGui:Destroy()
    end)
end)
