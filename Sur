local function npc()
    local lvl = Level.Value
    local targetName = "Giorno"
    local is175 = false

    if lvl >= 275 then targetName = "Young Joseph"
    elseif lvl >= 200 then targetName = "Zeppeli"
    elseif lvl >= 175 then targetName = "Giorno"; is175 = true
    elseif lvl >= 150 then targetName = "Muhammed Avdol"
    elseif lvl >= 125 then targetName = "DIO"
    elseif lvl >= 100 then targetName = "Rohan"
    elseif lvl >= 75 then targetName = "Josuke"
    elseif lvl >= 50 then targetName = "Joseph Joestar"
    elseif lvl >= 40 then targetName = "Okayasu"
    elseif lvl >= 30 then targetName = "aLLmemester"
    elseif lvl >= 20 then targetName = "Koichi"
    elseif lvl >= 10 then targetName = "Scared Noob"
    else targetName = "Giorno" 
    end

    local npcsFolder = workspace:FindFirstChild("Map") and workspace.Map:FindFirstChild("NPCs")
    if not npcsFolder then return targetName end
    
    for _, v in pairs(npcsFolder:GetChildren()) do
        if v.Name == targetName then
            if targetName == "Giorno" then
                local success, text = pcall(function() 
                    local textObj = v.Head.Main.Text
                    
                    if typeof(textObj) == "Instance" then
                        return textObj.Text
                    end
                    return textObj
                end)
                                
                if success and type(text) == "string" then
                    if is175 and string.find(text, "175") then
                        return v
                    elseif not is175 and not string.find(text, "175") then
                        return v
                    end
                end
            else
                return v
            end
        end
    end
    
    return npcsFolder:FindFirstChild(targetName) or targetName
end

local function getHRP()
    local char = LocalPlayer.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        local humanoid = char:FindFirstChildOfClass("Humanoid")
        if humanoid and humanoid.Health > 0 then
            return char.HumanoidRootPart
        end
    end
    return nil
end

local itemCache = {}

local function check(obj)
    if obj:IsA("BasePart") and obj.Name == ItemName then
        local prompt = obj:FindFirstChildOfClass("ProximityPrompt")
        if prompt then
            itemCache[obj] = prompt
        end
    end
end

for _, v in ipairs(workspace:GetDescendants()) do
    check(v)
end

workspace.DescendantAdded:Connect(function(descendant)
    task.defer(check, descendant)
end)

workspace.DescendantRemoving:Connect(function(descendant)
    if itemCache[descendant] then
        itemCache[descendant] = nil
    end
end)

local function nccam()
    pcall(function()
        local sc = (debug and debug.setconstant) or setconstant
        local gc = (debug and debug.getconstants) or getconstants
        local get_gc = getgc or getgc
        
        if not sc or not get_gc or not gc then return end
        
        local pop = LocalPlayer.PlayerScripts:WaitForChild("PlayerModule"):WaitForChild("CameraModule"):WaitForChild("ZoomController"):WaitForChild("Popper")
        for _, v in pairs(get_gc()) do
            if type(v) == 'function' and getfenv(v).script == pop then
                for i, v1 in pairs(gc(v)) do
                    if tonumber(v1) == 0.25 then
                        sc(v, i, 0)
                    elseif tonumber(v1) == 0 then
                        sc(v, i, 0.25)
                    end
                end
            end
        end
    end)
end

local function noclip()
    RunService.Stepped:Connect(function()
        if getgenv().AutoFarm then
            local character = LocalPlayer.Character
            if character then
                for _, part in pairs(character:GetDescendants()) do
                    if part:IsA("BasePart") and part.CanCollide then
                        part.CanCollide = false
                    end
                end
            end
        end
    end)
end

local function stand(character)
    for _, child in ipairs(character:GetChildren()) do
        if child:IsA("Model") and not child:IsA("Accessory") then
            for _, part in ipairs(child:GetDescendants()) do
                if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" and part.Transparency < 1 then
                    return true 
                end
            end
        end
    end
    return false 
end

local function summon()
    task.spawn(function()
        while task.wait(1) do 
            
            if getgenv().AutoFarm or getgenv().AutoLair then
                local character = LocalPlayer.Character
                if character and character:FindFirstChild("Humanoid") and character.Humanoid.Health > 0 then
                    local standEvents = character:FindFirstChild("StandEvents")
                    if standEvents then
                        local summonEvent = standEvents:FindFirstChild("Summon")
                        if summonEvent and summonEvent:IsA("RemoteEvent") then
                            if not stand(character) then
                                summonEvent:FireServer()
                                task.wait(2) 
                            end
                        end
                    end
                end
            end
        end
    end)
end

